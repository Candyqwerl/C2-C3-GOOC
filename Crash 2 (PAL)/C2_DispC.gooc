#include "C2_FruiC.gooh"
#include "C2_FONT_SMALL.gooc"
#include "C2_FONT_BIG.gooc"

expr BIG_FONT = 0x19C00
expr SMALL_FONT = 0x5500
expr DISPLAY_BOUND_Y = 190.0
expr DISPLAY_BOUND_LOWER_Y = 102.0

var mem1, mem2, mem3, mem4, mem5, mem6, mem7, mem8, mem9,
    mem10, DisplayFrame, DisplayVarField, DisplayStatus, DisplayFruitReward, DisplayParentID, ClearGemCount, ActiveDisplayOBJCount
    
inline sub DisplaySleep() {
    if (spawn == S_WUMPA_DISPLAY || spawn == S_BONUS_WUMPA_DISPLAY) {
        do {
            animframe = ((animframe + 1.0) % 14.0)
            playframe()
        } while (1)
    }
    else {
        sleepframe(DisplayFrame)
    }
}

inline sub PlayDisplayFrame() {
    if (spawn == S_WUMPA_DISPLAY || spawn == S_BONUS_WUMPA_DISPLAY) {
        animframe = ((animframe + 1.0) % 14.0)
        playframe()
    }
    else {
        playframe(DisplayFrame)
    }
}

inline sub SetTextLanguage_1(f1, f2) {
    if (field_62) {
        yzapproach = f1
    }
    else {
        yzapproach = f2
    }
}

inline sub SetTextLanguage_2(f1, f2) {
    if (field_62) {
        interrupter -> animframe = f1
    }
    else {
        interrupter -> animframe = f2
    }
}

inline sub KillDisplayChildren() {
    if (child) {
        cascadeevent(Event12, self)
        playnull()
    }
}

inline sub TextScaleDefault() {
    SetScale(0xA3, 0x103, 0x1000)
}

state HUD_Life_Display { // 0
    code() {
        LIFEICONTRANSX = 100.0
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetScale(3.2, 2.0, 2.0)
        x = 130.0
        vecy = DISPLAY_BOUND_Y
        z = 0
        DisplayFrame = 0
        DisplayVarField = 0x4100
        DisplayStatus = 0
        vecz = 0
        playanim(0, PICKUP_LIFE, 0.18s)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Display_Hidden)
    }
}

state HUD_Wumpa_Display { // 1
    code() {
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetScale(1.6, 2.0, 2.0)
        x = -200.0
        vecy = DISPLAY_BOUND_Y
        z = 0
        DisplayFrame = 0
        DisplayVarField = 0x4000
        DisplayStatus = 0
        vecz = 0
        playanim(0, FRUIT_WUMPA, 0.18s)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Display_Hidden)
    }
}

state HUD_Box_Display { // 2
    code() {
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 14
        vfx = (vfx & 0xFF00FFFF) | 0x40000
        SetScale(1.5, 1.2, 1.5)
        x = -40.0
        vecy = DISPLAY_BOUND_Y
        z = 0
        setanim(BOX_DISPLAY)
        DisplayFrame = 0
        DisplayVarField = 0x4900
        DisplayStatus = 0
        vecz = -10.0
        rotx = 40deg
        moda = 4.0
        SetColor2(-0xDD8, 0x6D7, 0x432)
        SetColor1(0x80, 0x80, 0x80)
        playframe(DisplayFrame, 0.18s)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Display_Hidden)
    }
}

state Display_Hidden { // 3
    statusc 0
    code() {
        statusb |= FLAG_INVISIBLE
        DisplaySleep()
    }
    event(e, a) {
        if (e == Event3 || e == Event32 || e == Event17) {
            if (DisplayStatus != 1) {
                DisplayStatus = 2
            } 
            statetime = frametime
            if (e == Event17) {
                DisplayStatus = 1
            }
        }
    }
    trans {
        // MIPS
        if (child) {
            sendevent(Event12, child)
        }
        v0 = getfield(player, DisplayVarField)
        if (!(v0 == getfield(self, DisplayVarField) || spawn == S_BOX_DISPLAY) || (buttonhold(PAD_TRIANGLE) || DisplayStatus)) {
            spawn2(DispC, S_VARIABLE_DISPLAY, 1, 32, -12.0, 16.0 - vecz, 40.0)
            changestate(Display_Show)
        }
    }
}

state Display_Show { // 4
    statusc 0
    event => state Display_Hidden
    code() {
        statusb &= ~FLAG_INVISIBLE
        DisplaySleep()
    }
    trans {
        once {
            if (spawn == S_BOX_DISPLAY) {
                settrans(BoxDisplayTrans)
                BoxDisplayTrans()
                return
            }
        }
        changestateif(Display_Hide, frametime - statetime >= 1.5s)
        vecy = seek(vecy, DISPLAY_BOUND_LOWER_Y, 10.0)
        if (vecy == DISPLAY_BOUND_LOWER_Y) {
            if (getfield(player, DisplayVarField) > getfield(self, DisplayVarField)) {
                unless(time(3)) {
                    statetime = frametime
                    if (spawn == S_WUMPA_DISPLAY) {
                        soundpitch(4.0)
                        soundsetup(0, 0, 11)
                        sounddecay(2.58s)
                        soundplay([tal0A], 0.2V)
                    }
                    setfield(self, DisplayVarField, getfield(self, DisplayVarField) + 1.0)
                }
            }
            else {
                setfield(self, DisplayVarField, getfield(player, DisplayVarField))
            }
            if (DisplayStatus == 1) {
                interrupter = child
                spawn2(FruiC, FruiC_S_1UP_GOTO_HUD, 1)
                if (interrupter == child) {
                    player -> mem2 += 1.0
                }
                DisplayStatus = 0
            }
            else {
                DisplayStatus = 0
            }
        }
        y = vecy + vecz
    }
}

sub BoxDisplayTrans() {
    if (getfield(self, DisplayVarField) < 10.0) {
        x = -40.0
    }
    else if (getfield(self, DisplayVarField) < 100.0) {
        x = -66.0
    }
    else {
        x = -82.0
    }
    roty = spd(roty, 180deg)
    changestateif(Display_Hide, frametime - statetime >= 1.5s)
    vecy = seek(vecy, DISPLAY_BOUND_LOWER_Y, 10.0)
    setfield(self, DisplayVarField, getfield(player, DisplayVarField))
    if (vecy == DISPLAY_BOUND_LOWER_Y) {
        DisplayStatus = 0
    }
    y = vecy + vecz
}

state Display_Hide { // 5
    statusc 0
    code => state Display_Show
    event => state Display_Hidden
    trans {
        v0 = getfield(player, DisplayVarField)
        changestateif(Display_Show, v0 != getfield(self, DisplayVarField) || buttonhold(PAD_TRIANGLE) || DisplayStatus)
        if (vecy < DISPLAY_BOUND_Y) {
            vecy += 4.0
        }
        else {
            changestate(Display_Hidden)
        }
        y = vecy + vecz
    }
}

state Variable_Display { // 6
    stateflag 0x40001
    event => state Menu_Button
    code(DisplayMode, base_x, y_off, x_off) {
        playnull()
        if (DisplayMode == 0x10) {
            invincible = SMALL_FONT
            TextScaleDefault()
        }
        else {
            invincible = BIG_FONT
            SetScale(0x146, 0x207, 16.0)
        }
        velx = base_x + x_off
        z = parent -> z
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetRot(0, 0, 0)
        if (parent -> spawn == S_WUMPA_DISPLAY || parent -> spawn == S_BONUS_WUMPA_DISPLAY) {
            SetColor1(0x1FF, 0x000, 0x000)
            SetColor2(0x1FF, 0x1FF, 0x000)
            SetColor3(0x1FF, 0x1FF, 0x000)
            SetColor4(0x000, 0x17C, 0x000)
        }
        else if (parent -> spawn == S_BOX_DISPLAY || parent -> spawn == S_BONUS_BOX_DISPLAY) {
            SetColor1(0xAC, 0x4E, 0x0C)
            SetColor2(0x9D, 0x3F, 0x09)
            SetColor3(0x8E, 0x30, 0x06)
            SetColor4(0x78, 0x28, 0x06)
        }
        else {
            TextColorDefault()
        }
        do {
            statusb = parent -> statusb
            x = parent -> x + velx
            y = parent -> y + y_off
            var v1 = getfield(parent, parent -> DisplayVarField) >> 8
            setanim(DISPLAY_TEXT)
            playframe(0)
        } while (1)
    }
}

state HUD_Bonus_Wumpa_Display { // 7
    stateflag 0x40001
    code() {
        movetolist(1.0)
        SetRot(0, 0, 0)
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetScale(0.8, 1.0, 1.0)
        x = -200.0
        y = -DISPLAY_BOUND_Y
        vely = -DISPLAY_BOUND_LOWER_Y
        z = 0
        setanim(FRUIT_WUMPA)
        DisplayFrame = 0
        DisplayVarField = 0x4300
        spawn(DispC, S_VARIABLE_DISPLAY, 1, 0x10, -8.0, 8.0, 20.0)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Bonus_Variable_Update)
    }
}

state HUD_Bonus_Life_Display { // 8
    stateflag 0x40001
    code() {
        movetolist(1.0)
        SetRot(0, 0, 0)
        spawn(DispC, S_BONUS_TEXT, 1, 0, 0x7000)
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetScale(1.6, 1.0, 1.0)
        x = 170.0
        y = -DISPLAY_BOUND_Y
        vely = -DISPLAY_BOUND_LOWER_Y
        z = 0
        setanim(PICKUP_LIFE)
        DisplayFrame = 0
        DisplayVarField = 0x4400
        spawn(DispC, S_VARIABLE_DISPLAY, 1, 0x10, -8.0, 8.0, 20.0)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Bonus_Variable_Update)
    }
}

state HUD_Bonus_Box_Display { // 9
    stateflag 0x40001
    code() {
        movetolist(1.0)
        SetRot(0, 0, 0)
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 14
        vfx = (vfx & 0xFF00FFFF) | 0x40000
        moda = 4.0
        SetColor2(-0xDD8, 0x6D7, 0x432)
        SetColor1(0x80, 0x80, 0x80)
        SetScale(1.0, 0.8, 1.0)
        x = -20.0
        y = -DISPLAY_BOUND_Y
        vely = -DISPLAY_BOUND_LOWER_Y
        z = 0
        setanim(BOX_DISPLAY)
        DisplayFrame = 0
        DisplayVarField = 0x4500
        spawn(DispC, S_VARIABLE_DISPLAY, 1, 0x10, 4.0, 8.0, 0x1400)
        setfield(self, DisplayVarField, getfield(player, DisplayVarField))
        changestate(Bonus_Variable_Update)
    }
}

state Bonus_Variable_Update { // 10
    stateflag 0x40001
    statusc 0
    code() {
        DisplaySleep()
    }
    event(e, a) {
        if (e == Event73) {
            if (a[0] == BONUS_COMPLETED) {
                accevcstate(Bonus_Reward_Items)
            }
            else {
                accevcstate(Bonus_Player_Death)
            }
        }
    }
    trans {
        // MIPS
        y = seek(y, vely, 10.0)
        if (y == vely) {
            if (getfield(player, DisplayVarField) > getfield(self, DisplayVarField)) {
                if (!time(3)) {
                    statetime = frametime
                    if (spawn == S_BONUS_WUMPA_DISPLAY) {
                        soundpitch(4.0)
                        soundsetup(0, 0, 11)
                        sounddecay(0.25)
                        soundplay([tal0A], 0.2V)
                    }
                    setfield(self, DisplayVarField, getfield(self, DisplayVarField) + 1.0)
                }
            }
            else {
                setfield(self, DisplayVarField, getfield(player, DisplayVarField))
            }
            if (spawn == S_BONUS_BOX_DISPLAY) {
                roty = spd(roty, 180deg)
            }
        }
    }
}

state Bonus_Reward_Items { // 11
    stateflag 0x40001
    statusc 0
    trans => state Bonus_Variable_Update
    code() {
        while (getfield(self, DisplayVarField) > 0) {
            if (spawn == S_BONUS_LIFE_DISPLAY) {
                interrupter = child
                save(scalex) {
                    scalex >>= 1
                    spawn2(FruiC, FruiC_S_1UP_GOTO_HUD, 1)
                }
                if (interrupter == child) {
                    player -> mem2 += 1.0
                }
                setfield(player, DisplayVarField, getfield(player, DisplayVarField) - 1.0)
                v0 = 0.35s
            }
            else if (spawn == S_BONUS_WUMPA_DISPLAY) {
                interrupter = child
                spawn2(FruiC, FruiC_S_WUMPA_BONUS_GOTO_HUD, 1)
                if (interrupter == child) {
                    player -> mem2 += 1.0
                }
                setfield(player, DisplayVarField, getfield(player, DisplayVarField) - 1.0)
                v0 = 0.15s
            }
            else if (spawn == S_BONUS_BOX_DISPLAY) {
                sendevent(EventBoxBreak, player, self)
                setfield(player, DisplayVarField, getfield(player, DisplayVarField) - 1.0)
                interrupter = BOXCOUNTER
                sendevent(Event32, interrupter, 0)
                v0 = 0.35s
            }
            do (var startframe = frametime){
                PlayDisplayFrame()
            } while (frametime - startframe < v0)
        }
        vely = -DISPLAY_BOUND_Y
        do {
            PlayDisplayFrame()
        } until(y == vely)
    }
}

expr FRUIT_ID_WUMPA = 76.0
expr FRUIT_ID_LIFE = 97.0

state Bonus_Player_Death { // 12
    stateflag 0x40001
    statusc 0
    trans => state Bonus_Variable_Update
    code() {
        while (getfield(self, DisplayVarField) > 0) {
            if (spawn == S_BONUS_WUMPA_DISPLAY) {
                spawn(FruiC, FruiC_S_FRUIT_BONUS_DEAD, 1, FRUIT_ID_WUMPA)
            }
            else if (spawn == S_BONUS_LIFE_DISPLAY) {
                spawn(FruiC, FruiC_S_FRUIT_BONUS_DEAD, 1, FRUIT_ID_LIFE)
            }
            setfield(self, DisplayVarField, getfield(self, DisplayVarField) - 1.0)
            PlayDisplayFrame()
            BONUSDEATHTIME = frametime
        }
        vely = -DISPLAY_BOUND_Y
        do {
            BONUSDEATHTIME = frametime
            PlayDisplayFrame()
        } until(y == vely)
    }
}

expr BONUS_B = 2.0
expr BONUS_BO = 3.0
expr BONUS_BON = 4.0
expr BONUS_BONU = 5.0
expr BONUS_BONUS = 1.0

inline sub DisplayBonusText(framenum, t) {
    setanim(DISPLAY_TEXT)
    playframe(framenum, t)
}

state Bonus_Text { // 13
    code(x_off, y_off) {
        x = x_off
        y = y_off
        z = 0
        SetScale(0x146, 0x207, 0x1000)
        invincible = BIG_FONT
        SetColor1(0x000, 0x1F4, 0x000)
        SetColor2(0x000, 0x1F4, 0x000)
        SetColor3(0x000, 0x190, 0x096)
        SetColor4(0x000, 0x190, 0x096)
        statusb = FLAG_STRING_CENTER
        zindex = 0x3E8
        v0 = 0
        do {
            vfx = (vfx & 0xFFFFFF00) | 0x6
            v0 = (v0 + 1) % 7
            if (v0 == 0 || v0 == 1) {
                setanim(DISPLAY_TEXT)
                playframe(BONUS_BONUS, 0.4s)
                vfx = (vfx & 0xFFFFFF00) | 0x1
                setanim(DISPLAY_TEXT)
                playframe(BONUS_BONUS, 0.18s)
            }
            else if (v0 == 2) DisplayBonusText(BONUS_B, 0.25s);
            else if (v0 == 3) DisplayBonusText(BONUS_BO, 0.25s);
            else if (v0 == 4) DisplayBonusText(BONUS_BON, 0.25s);
            else if (v0 == 5) DisplayBonusText(BONUS_BONU, 0.25s);
            else if (v0 == 6) DisplayBonusText(BONUS_BONUS, 0.25s);
            vfx = (vfx & 0xFFFFFF00) | 0x1
            DisplayBonusText(BONUS_BONUS, 2)
        } while (1)
    }
    event(e, a) {
        accevcstate(Display_Kill, e == Event73)
    }
}

sub SetLevelName(ID) {
    misc = 0
    if (ID == LEVEL_Intro)         misc = 0;
    if (ID == LEVEL_WarpRoom)      misc = 0;
 
    if (ID == LEVEL_TurtleWoods)   misc = 1;
    if (ID == LEVEL_SnowGo)        misc = 2;
    if (ID == LEVEL_HangEight)     misc = 3;
    if (ID == LEVEL_ThePits)       misc = 4;
    if (ID == LEVEL_CrashDash)     misc = 5;
 
    if (ID == LEVEL_SnowBiz)       misc = 6;
    if (ID == LEVEL_AirCrash)      misc = 7;
    if (ID == LEVEL_BearIt)        misc = 8;
    if (ID == LEVEL_CrashCrush)    misc = 9;
    if (ID == LEVEL_TheEelDeal)    misc = 10;
 
    if (ID == LEVEL_PlantFood)     misc = 11;
    if (ID == LEVEL_SewerOrLater)  misc = 12;
    if (ID == LEVEL_BearDown)      misc = 13;
    if (ID == LEVEL_RoadToRuin)    misc = 14;
    if (ID == LEVEL_Unbearable)    misc = 15;

    if (ID == LEVEL_HanginOut)     misc = 16;
    if (ID == LEVEL_DigginIt)      misc = 17;
    if (ID == LEVEL_ColdHardCrash) misc = 18;
    if (ID == LEVEL_Ruination)     misc = 19;
    if (ID == LEVEL_BeeHaving)     misc = 20;

    if (ID == LEVEL_PistonItAway)  misc = 21;
    if (ID == LEVEL_RockIt)        misc = 22;
    if (ID == LEVEL_NightFight)    misc = 23;
    if (ID == LEVEL_PackAttack)    misc = 24;
    if (ID == LEVEL_SpacedOut)     misc = 25;

    if (ID == LEVEL_TotallyBear)   misc = 26;
    if (ID == LEVEL_TotallyFly)    misc = 27;

    if (ID == LEVEL_BossRipperRoo) misc = -1;
    if (ID == LEVEL_BossKimodo)    misc = -2;
    if (ID == LEVEL_BossTazTiger)  misc = -3;
    if (ID == LEVEL_BossNGin)      misc = -4;
    if (ID == LEVEL_BossCortex)    misc = -5;
}

