                if (buttonpress(PAD_SELECT)) {
                    GLOBAL_152 = 0x80
                    GLOBAL_153 = 0x80
                    GLOBAL_154 = 0
                    GLOBAL_155 = 0
                    GLOBAL_156 = 0xFF
                    GLOBAL_157 = 0xFF
                    y = troty
                    if (var lang = GLOBAL_151; lang == GER) {
                        setanim(DISPLAY_TEXT)
                        playframe(108.0, 1.7s)
                    }
                    else if (lang == FRA) {
