                        }
                    }
                } until(buttonpress(PAD_X))

                if (vecx < JoyMinX) JoyMinX = vecx;
                if (vecy < JoyMinY) JoyMinY = vecy;
                if (vecx > JoyMaxX) JoyMaxX = vecx;
                if (vecy > JoyMaxY) JoyMaxY = vecy;
                S9 += 1.0
            }
            y = troty
            if (JoyMaxX - JoyCenterX > 64 && JoyCenterX - JoyMinX > 64 && JoyMaxY - JoyCenterY > 64 && JoyCenterY - JoyMinY > 64) {
                GLOBAL_152 = JoyCenterX
                GLOBAL_153 = JoyCenterY
                GLOBAL_154 = JoyMinX
                GLOBAL_155 = JoyMinY
                GLOBAL_156 = JoyMaxX
                GLOBAL_157 = JoyMaxY
                if (var lang = GLOBAL_151; lang == GER) {
