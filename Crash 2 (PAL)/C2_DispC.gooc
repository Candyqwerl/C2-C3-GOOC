                            playframe(115.0)
                        }
                        else {
                            setanim(DISPLAY_TEXT)
                            playframe(116.0)
                        }
                    }
                    else if (S9 == SPA) {
                        if (var lang = GLOBAL_151; lang == GER) {
                            setanim(DISPLAY_TEXT)
                            playframe(117.0)
                        }
                        else if (lang == FRA) {
                            setanim(DISPLAY_TEXT)
                            playframe(118.0)
                        }
                        else if (lang == ITA) {
                            setanim(DISPLAY_TEXT)
                            playframe(119.0)
                        }
                        else if (lang == SPA) {
