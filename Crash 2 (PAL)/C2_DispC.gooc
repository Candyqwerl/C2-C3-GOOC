                            playframe(121.0)
                        }
                    }
                    else if (S9 == 2.0) {
                        if (var lang = GLOBAL_151; lang == GER) {
                            setanim(DISPLAY_TEXT)
                            playframe(122.0)
                        }
                        else if (lang == FRA) {
                            setanim(DISPLAY_TEXT)
                            playframe(123.0)
                        }
                        else if (lang == ITA) {
                            setanim(DISPLAY_TEXT)
                            playframe(124.0)
                        }
                        else if (lang == SPA) {
                            setanim(DISPLAY_TEXT)
                            playframe(125.0)
                        }
                        else {
                            setanim(DISPLAY_TEXT)
                            playframe(126.0)
                        }
                    }
                    else {
                        if (var lang = GLOBAL_151; lang == GER) {
                            setanim(DISPLAY_TEXT)
                            playframe(127.0)
                        }
                        else if (lang == FRA) {
                            setanim(DISPLAY_TEXT)
                            playframe(128.0)
                        }
                        else if (lang == ITA) {
