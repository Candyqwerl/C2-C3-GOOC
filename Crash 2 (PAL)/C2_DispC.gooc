expr GER = 3.0
expr SPA = 1.0
expr ITA = 4.0
expr FRA = 2.0

state Pause_Menu_Root { // 14
    stateflag 0x100001
    code() {
        KillDisplayChildren()
        TextColorDefault()
        zindex = creator -> zindex
        if (player -> stateflag & 0x20) {
            field_61 = 2.0
        }
        else {
            field_61 = 3.0
        }
        SetLevelID(LEVEL)
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), misc, x - 80.0, -4.0, 0, 6.0, 74.0) // Level ID
        SetLevelName(LEVEL)
        DisplayFrame = misc
        if (DisplayFrame) {
            field_62 = DisplayFrame > 0
            if (var lang = GLOBAL_151; lang == GER) {
                SetTextLanguage_1(41.0, 42.0)
            }
            else if (lang == SPA) {
                SetTextLanguage_1(43.0, 44.0)
            }
            else if (lang == ITA) {
                SetTextLanguage_1(45.0, 42.0)
            }
            else if (lang == FRA) {
                SetTextLanguage_1(46.0, 47.0)
            }
            else {
                SetTextLanguage_1(48.0, 42.0)
            }
            spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), yzapproach, x - 80.0, -23.0, 0, 0, 74.0) // Level Name
            DisplayFrame = abs(DisplayFrame)
        }
        statusb = FLAG_NO_CAMERA_CLIP | FLAG_STRING_CENTER
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 49.0
        }
        else if (lang == SPA) {
            yzapproach = 50.0
        }
        else if (lang == ITA) {
            yzapproach = 51.0
        }
        else if (lang == FRA) {
            yzapproach = 52.0
        }
        else {
            yzapproach = 53.0
        }
        spawn(DispC, S_MENU_BUTTON, 1, 0, getanim(DISPLAY_TEXT), yzapproach, 0, 0, 0) // Resume Button
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 54.0
        }
        else if (lang == SPA) {
            yzapproach = 55.0
        }
        else if (lang == ITA) {
            yzapproach = 56.0
        }
        else {
            yzapproach = 57.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, 1.0, getanim(DISPLAY_TEXT), yzapproach, 0, -18.0, 0) // Options Button
        if (field_61 >= 3.0) {
            if (var lang = GLOBAL_151; lang == GER) {
                yzapproach = 58.0
            }
            else if (lang == SPA) {
                yzapproach = 59.0
            }
            else if (lang == ITA) {
                yzapproach = 60.0
            }
            else if (lang == FRA) {
                yzapproach = 61.0
            }
            else {
                yzapproach = 62.0
            }
            if (LEVEL == LEVEL_WarpRoom) {
                spawn2(DispC, S_MENU_BUTTON, 1, 2.0, getanim(DISPLAY_TEXT), yzapproach, 0, -36.0, 0) // Quit Button
            }
            else {
                spawn2(DispC, S_MENU_BUTTON, 1, 2.0, getanim(DISPLAY_TEXT), 8.0, 0, -36.0, 0) // WarpRoom Button
            }
        }
        sleepnull()
    }
    event(e, a) {
        accevcstate(Display_Kill, interrupter != self && e == Event12)
    }
    trans {
         once {
            TextScaleDefault()
            SetRot(0, 0, 0)
            stalltime = 0
            field_61 = 2.0
        }
        unless(STATUS_FIRSTFRAME) {
            unless(stateflag & 0x400000) {
                if (dirpress(PAD_UP) && stalltime > 0) {
                    stalltime -= 1.0
                }
                if (dirpress(PAD_DOWN) && stalltime < field_61 - 1.0) {
                    stalltime += 1.0
                }
                if (buttonpress(PAD_X)) {
                    if (var ButtonIndex = stalltime; ButtonIndex == 0) {
                        sendevent(Event12, parent)
                    }
                    else if (ButtonIndex == 1.0) {
                        changestate(Pause_Menu_Options, 0, 0, 0)
                    }
                    else if (ButtonIndex == 2.0) {
                        SUB_1165()
                    }
                }
            }
        }
        if (buttonpress(PAD_SELECT) && LEVEL != LEVEL_WarpRoom && field_61 >= 3.0) {
            SUB_1165()
        }
    }
}

sub SUB_1165() {
    sendevent(Event15, player, 6.0)
    if (LEVEL == LEVEL_WarpRoom) {
        GLOBAL_114 = 0
        GLOBAL_131 = 0
        GAMEFLAGS &= ~2
        GLOBAL_17 = 6.0
        loadlevel(LEVEL_Title)
    }
    else {
        loadlevel(LEVEL_WarpRoom)
    }
}

state Pause_Menu_Options { // 15
    stateflag 0x100001
    event => state Pause_Menu_Root
    code(FlightControlOBJ, __UA1, CTR_OBJ) {
        KillDisplayChildren()
        SetVec(-0x64, -0x64, -0x64)
        field_63 = -0x64
        FlightControlOBJ = 0
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 63.0
        }
        else if (lang == SPA) {
            yzapproach = 64.0
        }
        else if (lang == ITA) {
            yzapproach = 65.0
        }
        else if (lang == FRA) {
            yzapproach = 66.0
        }
        else {
            yzapproach = 67.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, 0, getanim(DISPLAY_TEXT), yzapproach, 0, 36.0, 0) // Music Options Button
        field_61 = 1.0
        if (LEVEL == LEVEL_RockIt || LEVEL == LEVEL_PackAttack || LEVEL == LEVEL_BossCortex) {
            spawn2(DispC, S_MENU_BUTTON, 1, field_61, getanim(DISPLAY_TEXT), 68.0, 0, 18.0, 0) // Flight Control Button
            FlightControlOBJ = objectspawned
            vecx = field_61
            field_61 += 1.0
        }
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 69.0
        }
        else if (lang == ITA) {
            yzapproach = 70.0
        }
        else {
            yzapproach = 71.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, field_61, getanim(DISPLAY_TEXT), yzapproach, 0, ((field_61 >> 8) - 2) * -18.0, 0) // CTR Offset Button
        CTR_OBJ = objectspawned
        field_63 = field_61
        field_61 += 1.0
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 72.0
        }
        else if (lang == ITA) {
            yzapproach = 73.0
        }
        else if (lang == SPA) {
            yzapproach = 74.0
        }
        else if (lang == FRA) {
            yzapproach = 75.0
        }
        else {
            yzapproach = 76.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, field_61, getanim(DISPLAY_TEXT), yzapproach, 0, ((field_61 >> 8) - 2) * -18.0, 0) // Calibrate Button
        vecy = field_61
        field_61 += 1.0
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 77.0
        }
        else if (lang == SPA) {
            yzapproach = 78.0
        }
        else if (lang == ITA) {
            yzapproach = 79.0
        }
        else if (lang == FRA) {
            yzapproach = 80.0
        }
        else {
            yzapproach = 81.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, field_61, getanim(DISPLAY_TEXT), yzapproach, 0, ((field_61 >> 8) - 2) * -18.0, 0) // Done Button
        field_61 += 1.0
        UpdateOptionValue()
        sleepnull()
    }
    trans {
        once {
            TextScaleDefault()
            SetRot(0, 0, 0)
            stalltime = 0
            field_61 = 2.0
        }
        unless(STATUS_FIRSTFRAME) {
            unless(stateflag & 0x400000) {
                if (dirpress(PAD_UP) && stalltime > 0) {
                    stalltime -= 1.0
                }
                if (dirpress(PAD_DOWN) && stalltime < field_61 - 1.0) {
                    stalltime += 1.0
                }
                if (buttonpress(PAD_X)) {
                    if (stalltime == 0) {
                        changestate(Pause_Menu_Sound_Options, 0, 0, 0)
                    }
                    else if (stalltime == vecx) {
                        GLOBAL_32 = GLOBAL_32 ^ 1
                    }
                    else if (stalltime == vecz) {
                        GLOBAL_32 = GLOBAL_32 ^ 2
                    }
                    else if (stalltime == vecy) {
                        nop()
                        //changestate(Pause_Menu_Calibrate) broken
                    }
                    else {
                        changestateif(Pause_Menu_Root, stalltime == field_61 - 1.0)
                    }
                }
            }
        }
        if (stalltime == field_63) {
            if (dirhold(PAD_W) && GLOBAL_91 > -15) {
                GLOBAL_91 -= 1
            }
            if (dirhold(PAD_E) && GLOBAL_91 < 15) {
                GLOBAL_91 += 1
            }
        }
        unless(STATUS_FIRSTFRAME) {
            UpdateOptionValue()
        }
    }
}

sub UpdateOptionValue(FlightControlOBJ, __UA1, CTR_OBJ) __trans {
    interrupter = FlightControlOBJ
    field_62 = GLOBAL_32 & 1
    if (var lang = GLOBAL_151; lang == GER) {
        SetTextLanguage_2(82.0, 68.0)
    }
    else if (lang == SPA) {
        SetTextLanguage_2(83.0, 84.0)
    }
    else if (lang == ITA) {
        SetTextLanguage_2(85.0, 86.0)
    }
    else if (lang == FRA) {
        SetTextLanguage_2(87.0, 88.0)
    }
    else {
        SetTextLanguage_2(89.0, 68.0)
    }
    interrupter = CTR_OBJ
    interrupter -> v0 = GLOBAL_91
}

state Pause_Menu_Sound_Options { // 16
    stateflag 0x100001
    event => state Pause_Menu_Root
    code(MonoStereoOBJ, MusicVolOBJ, SFXVolOBJ) {
        KillDisplayChildren()
        if (MONOSOUND) {
            animframe = 90.0
        }
        else {
            animframe = 91.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, 0, getanim(DISPLAY_TEXT), animframe, 0, 54.0, 0)
        MonoStereoOBJ = objectspawned
        spawn2(DispC, S_MENU_BUTTON, 1, 1.0, getanim(DISPLAY_TEXT), 92.0, 0, 18.0, 0)
        MusicVolOBJ = objectspawned
        spawn2(DispC, S_MENU_BUTTON, 1, 2.0, getanim(DISPLAY_TEXT), 92.0, 0, -18.0, 0)
        SFXVolOBJ = objectspawned
        UpdateVolumeValue()
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 93.0
        }
        else if (lang == FRA) {
            yzapproach = 94.0
        }
        else if (lang == SPA || lang == ITA) {
            yzapproach = 95.0
        }
        else {
            yzapproach = 96.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, -1.0, getanim(DISPLAY_TEXT), yzapproach, 0, 36.0, 0) // Music Volume Button
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 97.0
        }
        else if (lang == SPA) {
            yzapproach = 98.0
        }
        else if (lang == ITA) {
            yzapproach = 99.0
        }
        else if (lang == FRA) {
            yzapproach = 100.0
        }
        else {
            yzapproach = 101.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, -1.0, getanim(DISPLAY_TEXT), yzapproach, 0, 0, 0) // FX Volume Button
        if (var lang = GLOBAL_151; lang == GER) {
            yzapproach = 77.0
        }
        else if (lang == SPA) {
            yzapproach = 78.0
        }
        else if (lang == ITA) {
            yzapproach = 79.0
        }
        else if (lang == FRA) {
            yzapproach = 80.0
        }
        else {
            yzapproach = 81.0
        }
        spawn2(DispC, S_MENU_BUTTON, 1, 3.0, getanim(DISPLAY_TEXT), yzapproach, 0, -36.0, 0) // Done Button
        sleepnull()
    }
    trans {
        once {
            TextScaleDefault()
            SetRot(0, 0, 0)
            stalltime = 0
            field_61 = 4.0
        }
        unless(STATUS_FIRSTFRAME) {
            unless(stateflag & 0x400000) {
                if (dirpress(PAD_UP) && stalltime > 0) {
                    stalltime -= 1.0
                }
                if (dirpress(PAD_DOWN) && stalltime < field_61 - 1.0) {
                    stalltime += 1.0
                }
                if (buttonpress(PAD_X)) {
                    if (var ButtonIndex = stalltime; ButtonIndex == 0) {
                        MONOSOUND = !MONOSOUND
                    }
                    else {
                        changestateif(Pause_Menu_Root, ButtonIndex == 3.0)
                    }
                }
            }
        }
        unless(STATUS_FIRSTFRAME) {
            if (var ButtonIndex = stalltime; ButtonIndex == 0) {
                if (dirpress(PAD_W) || dirpress(PAD_E)) {
                    MONOSOUND = !MONOSOUND
                }
            }
            else if (ButtonIndex == 1.0) {
                if (dirhold(PAD_W) && MUSVOL > 0) {
                    MUSVOL -= 4
                }
                if (dirhold(PAD_E) && MUSVOL < 0xFF) {
                    MUSVOL += 4
                }
            }
            else if (ButtonIndex == 2.0) {
                if (dirhold(PAD_W) && SFXVOL > 0) {
                    SFXVOL -= 4
                }
                if (dirhold(PAD_E) && SFXVOL < 0xFF) {
                    SFXVOL += 4
                }
            }
            UpdateVolumeValue()
        }
    }
}

sub UpdateVolumeValue(MonoStereoOBJ, MusicVolOBJ, SFXVolOBJ) __trans {
    interrupter = MonoStereoOBJ
    if (!MONOSOUND) {
        if (var lang = GLOBAL_151; lang == SPA) {
            interrupter -> animframe = 102.0
        }
        else {
            interrupter -> animframe = 91.0
        }
    }
    else {
        interrupter -> animframe = 90.0
    }
    interrupter = MusicVolOBJ
    interrupter -> v0 = MUSVOL * 100 / 255
    interrupter = SFXVolOBJ
    interrupter -> v0 = SFXVOL * 100 / 255
}

state Pause_Menu_Calibrate { // 17
    stateflag 0x100001
    event => state Pause_Menu_Root
    code() {
        KillDisplayChildren()
        trotx = x
        troty = y
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        x -= 88.0
        y += 37.0
        {
            var JoyMinX = 1.0
            var JoyMinY = 1.0
            var JoyMaxX = -1
            var JoyMaxY = -1
            var JoyCenterX = 0x80
            var JoyCenterY = 0x80
            var S9 = 0
            do {
                if (var lang = GLOBAL_151; lang == GER) {
                    setanim(DISPLAY_TEXT)
                    playframe(103.0)
                }
                else if (lang == FRA) {
                    setanim(DISPLAY_TEXT)
                    playframe(104.0)
                }
                else if (lang == ITA) {
                    setanim(DISPLAY_TEXT)
                    playframe(105.0)
