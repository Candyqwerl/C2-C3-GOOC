state Pause_Menu_Init { // 18
    stateflag 0x100001
    code() {
        stalltime = GAMEFLAGS
        do {
            GLOBAL_73 = seek(GLOBAL_73, 8, 1)
            playnull()
        } until(GLOBAL_73 == 8)
        playnull()
        playnull()
        GAMEFLAGS &= ~0x8042001
        playnull()
        GLOBAL_73 = 0
        playnull()
        spawn2(DispC, S_PAUSE_BACKGROUND, 1)
        playnull()
        while (child -> stateflag & 0x8000) {
            playnull()
        }
        TextColorDefault()
        zindex = 0x64
        TextScaleDefault()
        ActiveDisplayOBJCount = GLOBAL_23
        if (ActiveDisplayOBJCount) {
            misc = 142.0
        }
        else {
            misc = 143.0
        }
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), misc, 84.0, 118.0, 0, 0, 80.0)
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), 144.0, 100.0, 85.0, 0, 0, 77.0) 
        spawn2(DispC, S_INVENTORY, 1, 200.0, 190.0, 67.0, 0)
        do (var v1 = SAVEDGEMPOOL1, v2 = SAVEDGEMPOOL2, i = 0) {
            if (var ItemOffs = 58 + (i >> 8); ItemOffs < 32) {
                misc = v1 & 1 << ItemOffs
            }
            else {
                misc = v2 & 1 << (ItemOffs - 32)
            }
            if (misc) {
                misc = 4
            }
            else {
                misc = 2
            }
            spawn2(DispC, S_INVENTORY, 1, 358.0 + i, 84.0 + (i * 36) - 5.0, 23.0, misc)
            i += 1.0
        } while (i < 5.0)
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), 145.0, 86.0, 11.0, 0, 0, 79.0)
        spawn2(DispC, S_INVENTORY, 1, 300.0, 172.0, 0, 0)
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), 146.0, 84.0, -17.0, 0, 0, 78.0)
        x = -144.0
        y = -61.0
        spawn2(DispC, S_PAUSE_MENU_ROOT, 1)
        creator = objectspawned
        SetScale(0x146, 0x207, 0x1000)
        {
            var v1 = SAVEDCRYSTALPOOL1
            var v2 = SAVEDCRYSTALPOOL2

            misc = 0
            do (var i = 0) { if (GLOBAL_27 & 1 << i) { misc += 1 } i += 1 } while (i < 32)
            do (var i = 0) { if (GLOBAL_28 & 1 << i) { misc += 1 } i += 1 } while (i < 32)

            DisplayStatus = misc 
            misc = 0 

            do (var i = 0) { if (v1 & 1 << i) { misc += 1 } i += 1 } while (i < 32)
            do (var i = 0) { if (v2 & 1 << i) { misc += 1 } i += 1 } while (i < 32)

            DisplayFruitReward = misc 
            v1 = SAVEDGEMPOOL1
            v2 = SAVEDGEMPOOL2
            misc = 0

            do (var i = 0) { if (v1 & 1 << i) { misc += 1 } i += 1 } while (i < 32)
            do (var i = 0) { if (v2 & 1 << i) { misc += 1 } i += 1 } while (i < 32)

            DisplayParentID = misc
            v2 &= ~0x3FFFFFF
            misc = 0

            do (var i = 0) { if (v2 & 1 << i) { misc += 1 } i += 1 } while (i < 32)

            ClearGemCount = DisplayParentID - misc
            misc = 0

            do (var i = 0) { if (GLOBAL_150 & 31 & 1 << i) { misc += 1 } i += 1 } while (i < 32)

            groundy = misc
            DisplayVarField = (DisplayFruitReward << 1) + (DisplayParentID + groundy)

            if (GLOBAL_27 & 0x80) {
                DisplayVarField += 3
            }
        }
        spawn2(DispC, S_MENU_TEXT, 1, getanim(DISPLAY_TEXT), 147.0, 148.0, -75.0, 6, 5.0, 75.0)
        sleepnull()
    }
    event(e, a) {
        accevcstate(Pause_Menu_Close, e == Event12 && interrupter != self)
    }
}

state Pause_Menu_Close { // 19
    stateflag 0x100001
    statusc 0x3
    code() {
        cascadeevent(Event12, 0)
        while (child) playnull();
        GLOBAL_73 = 8
        GAMEFLAGS = stalltime
        playnull()
        playnull()
        do {
            playnull()
            GLOBAL_73 = seek(GLOBAL_73, 0, 1)
        } while (GLOBAL_73)
        GLOBAL_12 = 0
    }
}

state HUD_Collectable_Display { // 20
    statusc 0
    code(FruitRewardID, pos_x, StartHidden) {
        SetGemAttributes(FruitRewardID)
        if (StartHidden) {
            if (animseq == getanim(GEM_1)) {
                animseq = 0
            }
            statusb = FLAG_INVISIBLE
            y = -DISPLAY_BOUND_LOWER_Y
            v0 = 0
        }
        else {
            y = -DISPLAY_BOUND_Y
            v0 = getfield(player, DisplayVarField)
        }
        x = pos_x
        changestate(HUD_Collectable_Display_Show)
    }
}

state HUD_Collectable_Display_Show { // 21
    statusc 0
    code() {
        sleepframe(DisplayFrame)
    }
    trans {
        changestateif(HUD_Collectable_Display_Hide, frametime - statetime >= 1.5s)
        y = seek(y, -DISPLAY_BOUND_LOWER_Y, 10.0)
        roty = spd(roty, 180deg)
        if (DisplayFruitReward >= 200.0 && getfield(player, DisplayVarField) > v0) {
            statusb &= ~FLAG_INVISIBLE
            if (DisplayFruitReward >= 300.0) {
                SetGemColor(getfield(player, DisplayVarField))
            }
        }
    }
}

state HUD_Collectable_Display_Hide { // 22
    statusc 0
    code() {
        do {
            y = seek(y, -DISPLAY_BOUND_Y, 4.0)
            playframe(DisplayFrame)
        } until(y == -DISPLAY_BOUND_Y)
        sendevent(Event1, parent)
    }
    trans {
        changestateif(HUD_Collectable_Display_Show, buttonhold(PAD_TRIANGLE) && v0 == getfield(player, DisplayVarField))
        roty = spd(roty, 180deg)
    }
}

expr GEM_RED = 58.0
expr GEM_GREEN = 59.0
expr GEM_PURPLE = 60.0
expr GEM_BLUE = 61.0
expr GEM_YELLOW = 62.0

sub SetGemColor(FruitRewardID){
    if (FruitRewardID == GEM_RED) {
        SetColor1(0x6C, 0x08, 0x08)
        setanim(GEM_1)
    }
    else if (FruitRewardID == GEM_GREEN) {
        SetColor1(0x08, 0x6C, 0x08)
        setanim(GEM_2)
    }
    else if (FruitRewardID == GEM_PURPLE) {
        SetColor1(0x6C, 0x08, 0x6C)
        setanim(GEM_3)
    }
    else if (FruitRewardID == GEM_BLUE) {
        SetColor1(0x00, 0x00, 0x80)
        if (animseq != getanim(GEM_1)) {
            scalex = scalex * 1.2 >> 8
            scaley = scaley * 0.6 >> 8
            scalez = scalez * 1.2 >> 8
        }
        setanim(GEM_1)
    }
    else if (FruitRewardID == GEM_YELLOW) {
        SetColor1(0x80, 0x80, 0x00)
        if (animseq != getanim(GEM_1)) {
            scalex = scalex * 0.9 >> 8
            scaley = scaley * 1.2 >> 8
            scalez = scalez * 0.9 >> 8
        }
        setanim(GEM_1)
    }
    else {
        SetColor1(0x5A, 0x5A, 0x6C)
        setanim(GEM_1)
    }
    moda = 4.0
    SetColor2(0x00, 0xE77, 0x6D7)
}

sub SetGemAttributes(FruitRewardID){
    DisplayFruitReward = FruitRewardID
    SetScale(0x147, 0x147, 0x147)
    vfx = (vfx & 0xFFFFFF00) | 11
    vfx = (vfx & 0xFF00FFFF) | 0x40000
    if (FruitRewardID == 200.0) {
        SetColorC2Obj(4.0, 0x80, 0x80, 0x80, -0xCCC, -0x800, 0x00)
        setanim(CRYSTAL)
        DisplayFrame = 0
        DisplayVarField = 0x4600
        if (!child) {
            spawn2(9, 47, 1, 0)
        } 
    }
    else if (FruitRewardID == 300.0) {
        animseq = 0
        DisplayFrame = 0
        DisplayVarField = 0x4700
        SetGemColor(player -> mem8)
    }
    else if (FruitRewardID == 301.0) {
        animseq = 0
        DisplayFrame = 0
        DisplayVarField = 0x4800
        SetGemColor(player -> mem9)
    }
}

sub CheckPlayerInventory(FruitRewardID, pos_x, StartHidden) {
    var v1 = 0
    var v2 = child
    if (StartHidden) {
        x = pos_x
        v1 = 1.0
    }
    else if (FruitRewardID == 200.0) {
        v1 = player -> mem7
    }
    else if (FruitRewardID == 300.0) {
        v1 = player -> mem8
    }
    else if (FruitRewardID == 301.0) {
        v1 = player -> mem9
    }
    if (v1) {
        spawn2(DispC, S_COLLECTABLE_DISPLAY, 1, FruitRewardID, pos_x, StartHidden)
        if (v2 != child) {
            ActiveDisplayOBJCount += 1.0
        }
    }
}

state Collectable_Manager_Init { // 23
    code() {
        statusb = FLAG_NO_CAMERA_CLIP | FLAG_INVISIBLE
        vfx = (vfx & 0xFFFFFF00) | 0x6
        x = 0
        z = 0
        DisplayStatus = 0
        ActiveDisplayOBJCount = 0
        changestate(Collectable_Manager)
    }
}

state Collectable_Manager { // 24
    code() {
        statusb |= FLAG_INVISIBLE
        y = DISPLAY_BOUND_Y
        sleepframe(DisplayFrame)
    }
    event(e, a) {
        if (e == Event32) {
            DisplayFruitReward = a[0]
            DisplayParentID = a[1.0]
            if (ActiveDisplayOBJCount == 0) {
                if (DisplayFruitReward == 200.0) {
                    CheckPlayerInventory(200.0, 0, 1.0)
                }
                else if (DisplayFruitReward == 300.0) {
                    CheckPlayerInventory(300.0, -40.0, 1.0)
                }
                else if (DisplayFruitReward == 301.0) {
                    CheckPlayerInventory(301.0, 40.0, 1.0)
                }
            }
            accevret()
        }
        if (e == Event1) {
            ActiveDisplayOBJCount -= 1.0
        }
    }
    trans {
        if (buttonhold(PAD_TRIANGLE)) {
            if (ActiveDisplayOBJCount == 0 && !(GLOBAL_119 & 0x2000 && BONUSSTATE != BONUS_COMPLETED)) {
                CheckPlayerInventory(200.0, 0, 0)
                CheckPlayerInventory(300.0, -40.0, 0)
                CheckPlayerInventory(301.0, 40.0, 0)
            }
        }
    }
}

state Demo_Text { // 25
    stateflag 0x40001
    code(pos_x, pos_y) {
        statusb = FLAG_STRING_CENTER
        vfx = (vfx & 0xFFFFFF00) | 0x6
        zindex = 100
        DEMOTEXTOBJ = self
        x = pos_x
        y = pos_y
        z = 0
        TextScaleDefault()
        TextColorDefault()
        do {
            setanim(DISPLAY_TEXT)
            playframe(148.0, 0.4s)
            playnull(0.4s)
        } while (1)
    }
    event(e, a) {
        accevcstate(Demo_Text_Sleep, e == Event14)
    }
}

state Demo_Text_Sleep { // 26
    code() {
        if (LEVEL == LEVEL_WarpRoom) sleepnull();
        GAMEFLAGS &= ~2
        GLOBAL_17 = 6.0
        loadlevel(LEVEL_Title)
        sleepnull()
    }
}

state Display_Kill { // 27
    stateflag 0x100020
    statusc 0
    code() { }
}

state Box_Counter { // 28
    code() {
        vfx = (vfx & 0xFFFFFF00) | 5
        y += 1.5m
        statusb = FLAG_STRING_CENTER
        TextColorDefault()
        SetScale(8.0)
        invincible = BIG_FONT
        if (var v1 = SAVEDGEMPOOL1 | GEMPOOL1, v2 = SAVEDGEMPOOL2 | GEMPOOL2; LEVEL == LEVEL_TurtleWoods) {
            unless (0x20000000 & v2) {
                if (BOXCOUNT == 0) {
                    changestate(Box_Counter_Reward, 361.0)
                }
                else if (field_61) {
                    field_61 = 0
                    GLOBAL_148 = 0
                }
            }
        }
        else if (LEVEL == LEVEL_HangEight) {
            changestateif(Box_Counter_Reward, !(frametime - GLOBAL_66 >= 75.0s) && !(2 & v1), 301.0)
        }
        else if (LEVEL == LEVEL_PlantFood) {
            changestateif(Box_Counter_Reward, !(frametime - GLOBAL_66 >= 85.0s) && !(0x40000000 & v2), 362.0)
        }
        playnull()
        spawn2(DispC, S_HOLOGRAM, 1, x, y - 1.0m, z)
        do {
            var v1 = GLOBAL_148 >> 8
            var v2 = BOXCOUNT >> 8
            setanim(DISPLAY_TEXT)
            playframe(149.0)
        } while (1)
    }
    trans {
        once {
            if (var ItemOffs = LEVEL >> 8; ItemOffs < 32) {
                misc = SAVEDGEMPOOL1 & (1 << ItemOffs)
            }
            else {
                misc = SAVEDGEMPOOL2 & (1 << (ItemOffs - 32))
            }
            field_61 = misc
            if (var ItemOffs = LEVEL >> 8; ItemOffs < 32) {
                misc = GEMPOOL1 & (1 << ItemOffs)
            }
            else {
                misc = GEMPOOL2 & (1 << (ItemOffs - 32))
            }
            field_61 = field_61 || misc
        }
        changestateif(Box_Counter_Reward, (BOXCOUNT == GLOBAL_148 || entitygetstate(3) || field_61) && !STATUS_FIRSTFRAME, 300.0 + LEVEL)
    }
}

state Box_Counter_Reward { // 29
    code(FruitRewardID) {
        calcpath(0)
        cascadeevent(Event12, self)
        if (var ItemOffs = FruitRewardID - 300.0 >> 8; ItemOffs < 32) {
            misc = SAVEDGEMPOOL1 & (1 << ItemOffs)
        }
        else {
            misc = SAVEDGEMPOOL2 & (1 << (ItemOffs - 32))
        }
        field_61 = misc
        if (var ItemOffs = FruitRewardID - 300.0 >> 8; ItemOffs < 32) {
            misc = GEMPOOL1 & (1 << ItemOffs)
        }
        else {
            misc = GEMPOOL2 & (1 << (ItemOffs - 32))
        }
        field_61 = field_61 || misc
        if (entitygetstate(3) || field_61) {
            entitysetspawn(0)
        }
        else {
            spawn2(FruiC, FruiC_S_FRUIT_HOP, 1, FruitRewardID, id)
            creator = objectspawned
            do {
                playnull(1.7s)
            } until(entitygetstate(3))
        }
    }
}

state River_TimeTrial { // 30
    stateflag 0x40001
    code() { 
        vfx = (vfx & 0xFFFFFF00) | 0x6
        SetScale(0x146, 0x207, 0x1000)
        invincible = BIG_FONT
        TextColorDefault()
        zindex = 0x64
        {
            var v1 = SAVEDGEMPOOL1 | GEMPOOL1
            var v2 = SAVEDGEMPOOL2 | GEMPOOL2
            if (LEVEL == LEVEL_HangEight) {
                vecz = 1
                v0 = 75.0s
                field_61 = 408.84m
                vecy = 25.0s
            }
            else if (LEVEL == LEVEL_PlantFood) {
                vecz = 62
                v0 = 85.0s
                field_61 = 507.1575m
                vecy = 30.0s
            }
        
            if (var ItemOffs = vecz; ItemOffs < 32) {
                misc = v1 & (1 << ItemOffs)
            }
            else {
                misc = v1 & (1 << ItemOffs)
            }
            if (misc) {
                return
            }
        }
        if (player -> z < field_61)  return;
        do { playnull() } until(frametime - GLOBAL_66 >= v0 || player -> z < field_61 && !(frametime - GLOBAL_66 >= vecy))
        x = 100.0
        y = -82.0
        z = 0.0
        do {
            vecx = v0 - (frametime - GLOBAL_66)
            var v1 = (vecx / 25) % 60
            var v2 = vecx / 1500
            setanim(DISPLAY_TEXT)
            playframe(150.0)
            if (var ItemOffs = vecz; vecz < 32) {
                misc = (GEMPOOL1 & 1) << ItemOffs
            }
            else {
                misc = (GEMPOOL2 & 1) << ItemOffs - 32
            }
        } while (!misc && !(GLOBAL_119 & 0x2000) && !(frametime - GLOBAL_66 >= v0))
        creator = objectget(50.0)
        if (creator) {
            interrupter = creator -> creator
            sendevent(Event14, interrupter, 100.0)
        }
    }
    event(e, a) {
        accevcstate(Display_Kill, e == Event19)
    }
}

state Menu_Button { // 31
    stateflag 0x120001
    __transargs
    code(ButtonIndex, anim, framenum, x_off, y_off, a0) {
        statusb = creator -> statusb
        zindex = creator -> zindex
        unless(creator -> stateflag & 0x100000) {
            stateflag &= ~0x100000
        }
        vfx = (vfx & 0xFFFFFF00) | 0x6
        invincible = SMALL_FONT
        animseq = anim
        animframe = framenum
        var v1 = v0
        do {
            v1 = v0
            playframe()
        } while (1)
    }
    trans {
        // MIPS
        x = creator -> x + x_off
        y = creator -> y + y_off
        TextFlash(ButtonIndex)
    }
    event(e, a) {
        accevcstate(Display_Kill, e == Event12 || e == Event1)
    }
}

sub TextFlash(ButtonIndex) {
    if (ButtonIndex == creator -> stalltime) {
        TextFlashFast()
    }
    else {
        SetTextColor(0xA0, 0x8B, 0x60, 0xA0, 0x60, 0x06)
    }
}

state Menu_Text { // 32
    stateflag 0x100001
    event => state Menu_Button
    code(anim, framenum, x_off, y_off, DisplayFlags, TextColor, VarField) {
        if (TextColor == 0) {
            TextColorDefault()
        }
        else if (TextColor == 2.0) {
            SetTextColor(0xFF, 0xFF, 0xFF, 0x40, 0x40, 0x40)
        }
        else if (TextColor == 5.0) {
            SetTextColor(0x1FF, 0x190, 0x00, 0x1FF, 0x00, 0x00)
            settrans(TextFlashSlow)
        }
        else if (TextColor == 6.0) {
            SetTextColor(0x1FF, 0x190, 0x00, 0x1FF, 0x00, 0x00)
            settrans(TextFlashMedium)
        }
        if (DisplayFlags & 1) {
            x = parent -> x + x_off
            y = parent -> y + y_off
        }
        else {
            x = x_off
            y = y_off
        }
        if (DisplayFlags & 4) {
            invincible = BIG_FONT
        }
        else {
            invincible = SMALL_FONT
        }
        zindex = creator -> zindex
        if (DisplayFlags & 2) {
            statusb |= FLAG_STRING_CENTER
        }
        else {
            statusb &= ~FLAG_STRING_CENTER
        }
        unless(creator -> stateflag & 0x100000) {
            stateflag &= ~0x100000
        }
        vfx = (vfx & 0xFFFFFF00) | 6
        animseq = anim
        do (var v1) {
            v1 = getfield(creator, VarField)
            playframe(framenum)
        } while (1)
    }
}

sub TextFlashSlow() {
    if (frametime & 31) {
        SetTextColor(0x1FF, 0x190, 0x00, 0x1FF, 0x00, 0x00)
    }
    else {
        SetTextColor(0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF)
    }
} 

sub TextFlashMedium() {
    if ((frametime & 31) == 15) {
        SetTextColor(0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF)
    }
    else {
        SetTextColor(0x1FF, 0x190, 0x00, 0x1FF, 0x00, 0x00)
    }
}

sub TextFlashFast() {
    if (frametime & 3) {
        SetTextColor(0x1FF, 0x190, 0x00, 0x1FF, 0x00, 0x00)
    }
    else {
        SetTextColor(0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF, 0x1FF)
    }
}

state Pause_Menu_Inventory { // 33
    stateflag 0x100001
    event => state Menu_Button
    code(FruitRewardID, x_off, y_off, DisplayFlags) {
        if (DisplayFlags & 1) {
            x = parent -> x + x_off
            y = parent -> y + y_off
        }
        else {
            x = x_off
            y = y_off
        }
        troty = 10deg + rand(10deg)
        trotx = 0
        statusb = creator -> statusb
        zindex = creator -> zindex
        zindex = 0
        unless(creator -> stateflag & 0x100000) {
            stateflag &= ~0x100000
        }
        vfx = (vfx & 0xFFFFFF00) | 14
        vfx = (vfx & 0xFF00FFFF) | 0x40000
        if (FruitRewardID == 97.0) {
            tpc = 0
            setanim(PICKUP_LIFE)
            SetScale(0x146, 0x103, 0x1000)
        }
        else if (FruitRewardID >= 300.0) {
            if (DisplayFlags & 8) {
                SetScale(0x8F, 0x8F, 0x8F)
            }
            else if (DisplayFlags & 4) {
                SetScale(0xA3, 0xA3, 0xA3)
            }
            else {
                SetScale(0x11E, 0x11E, 0x11E)
            }
            SetGemColor(FruitRewardID - 300.0)
            if (DisplayFlags & 8) {
                SetColor2(-0x2C1, 0x78B, 0xDD6)
                SetColor1(0xA0, 0xA0, 0xA0)
            }
            else {
                SetColor2(-0x2C1, 0x78B, 0xDD6)
            }
            rotx = 20deg
            rotz = 0
            if (DisplayFlags & 2) {
                do {
                    SetScale(40, 40, 40)
                    do {
                        playframe(0)
                    } while (rand(0xC8))
                    SetScale(0x51, 0x51, 0x51)
                    playframe(0)
                    SetScale(0xA3, 0xA3, 0xA3)
                    playframe(0, 0.08s)
                    SetScale(0x51, 0x51, 0x51)
                    playframe(0)
                } while (1)
            }
        }
        else if (FruitRewardID >= 200.0) {
            if (DisplayFlags & 8) {
                SetScale(0x7A, 0x7A, 0x7A)
            }
            else {
                SetScale(1.0, 1.0, 1.0)
            }
            SetColorC2Obj(4.0, 0x80, 0x80, 0x80, -0x8B5, -0x83A, 0xA9B)
            setanim(CRYSTAL)
            spawn2(9, 47, 1, 0)
        }
        sleepframe(0)
    }
    trans {
        roty = spd(roty, 90deg)
    }
}

state Pause_Menu_Background { // 34
    stateflag 0x108001
    code() {
        statusb = FLAG_NO_CAMERA_CLIP
        vfx = (vfx & 0xFFFFFF00) | 0x6
        vfx = (vfx & 0xFFFF00FF) | 0x100
        x = 0
        y = 0
        z = 0
        TextScaleDefault()
        zindex = -0x3E8
        moda = 16.0
        while (moda) {
            moda = seek(moda, 0, 0x555)
            playanim(0, PAUSE_BACKGROUND)
        }
        stateflag &= ~0x8000
        sleepanim(0, PAUSE_BACKGROUND)
    }
    event(e, a) {
        accevcstate(Pause_Menu_Background_Kill, e == Event12)
    }
}

state Pause_Menu_Background_Kill { // 35
    stateflag 0x100001
    code() {
        while (moda < 16.0) {
            moda = seek(moda, 16.0, 0x555)
            playanim(0, PAUSE_BACKGROUND)
        }
        playanim(0, PAUSE_BACKGROUND)
    }
}

state Box_Hologram { // 36
    event => state Pause_Menu_Root
    code(pos_x, pos_y, pos_z) {
        SetScale(0x1CCC)
        x = pos_x
        y = pos_y
        z = pos_z
        vfx = (vfx & 0xFF00FFFF) | 0x20000
        moda = v0
        zindex = 20
        sleepanim(0, BOX_PICKUP)
    }
    trans {
        once {
            v0 = 6.4
        }
        unless(rand(10)) {
            v0 = 1.6 + rand(6.4)
        }
        field_61 = abs(z - CAMTRANSZ)
        if (field_61 < 4.0m) {
            if (field_61 <= 1.0m) {
                v0 = 16.0
            }
            else {
                v0 = 16.0 - 1.0 / (field_61 * 6.4)
            }
        }
        moda = seek(moda, v0, 0x111)
        roty = spd(roty, 180deg)
    }
}

sub TextColorDefault() {
    SetTextColor(0x1FF, 0x190, 0, 0x1FF, 0, 0)
}

