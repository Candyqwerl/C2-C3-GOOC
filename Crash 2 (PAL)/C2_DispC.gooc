    if (ID == LEVEL_SnowGo)        misc = 10.0;
    if (ID == LEVEL_HangEight)     misc = 11.0;
    if (ID == LEVEL_ThePits)       misc = 12.0;
    if (ID == LEVEL_CrashDash)     misc = 13.0;

    if (ID == LEVEL_SnowBiz)       misc = 14.0;
    if (ID == LEVEL_AirCrash)      misc = 15.0;
    if (ID == LEVEL_BearIt)        misc = 16.0;
    if (ID == LEVEL_CrashCrush)    misc = 17.0;
    if (ID == LEVEL_TheEelDeal)    misc = 18.0;

    if (ID == LEVEL_PlantFood)     misc = 19.0;
    if (ID == LEVEL_SewerOrLater)  misc = 20.0;
    if (ID == LEVEL_BearDown)      misc = 21.0;
    if (ID == LEVEL_RoadToRuin)    misc = 22.0;
    if (ID == LEVEL_Unbearable)    misc = 23.0;

    if (ID == LEVEL_HanginOut)     misc = 24.0;
    if (ID == LEVEL_DigginIt)      misc = 25.0;
    if (ID == LEVEL_ColdHardCrash) misc = 26.0;
    if (ID == LEVEL_Ruination)     misc = 27.0;
